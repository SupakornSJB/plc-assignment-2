Grammar:

Rule 0     S' -> program
Rule 1     program -> expr
Rule 2     program -> statement_list
Rule 3     statement_list -> <empty>
Rule 4     statement_list -> statement statement_list
Rule 5     statement -> FUNCTION IDENTIFIER ( param_list ) { statement_list return_stmt }
Rule 6     statement -> WHILE ( bool_expr ) { statement_list }
Rule 7     statement -> IF ( bool_expr ) { statement_list } else_clause
Rule 8     statement -> PRINT ( expr )
Rule 9     statement -> IDENTIFIER ASSIGN expr
Rule 10    bool_expr -> expr
Rule 11    else_clause -> <empty>
Rule 12    else_clause -> ELSE { statement_list }
Rule 13    param_list -> <empty>
Rule 14    param_list -> IDENTIFIER
Rule 15    param_list -> IDENTIFIER , param_list
Rule 16    return_stmt -> <empty>
Rule 17    return_stmt -> RETURN expr
Rule 18    expr -> ( expr )
Rule 19    expr -> BOOLEAN
Rule 20    expr -> STRING
Rule 21    expr -> FLOAT
Rule 22    expr -> INTEGER
Rule 23    expr -> IDENTIFIER
Rule 24    expr -> IDENTIFIER ( arg_list )
Rule 25    expr -> FUMINUS expr  [precedence=right, level=4]
Rule 26    expr -> UMINUS expr  [precedence=right, level=4]
Rule 27    expr -> expr FNEQ expr  [precedence=left, level=1]
Rule 28    expr -> expr FEQ expr  [precedence=left, level=1]
Rule 29    expr -> expr NEQ expr  [precedence=left, level=1]
Rule 30    expr -> expr EQ expr  [precedence=left, level=1]
Rule 31    expr -> expr CONCAT expr  [precedence=left, level=2]
Rule 32    expr -> expr FDIVIDE expr  [precedence=left, level=3]
Rule 33    expr -> expr FTIMES expr  [precedence=left, level=3]
Rule 34    expr -> expr FMINUS expr  [precedence=left, level=2]
Rule 35    expr -> expr FPLUS expr  [precedence=left, level=2]
Rule 36    expr -> expr DIVIDE expr  [precedence=left, level=3]
Rule 37    expr -> expr TIMES expr  [precedence=left, level=3]
Rule 38    expr -> expr MINUS expr  [precedence=left, level=2]
Rule 39    expr -> expr PLUS expr  [precedence=left, level=2]
Rule 40    arg_list -> <empty>
Rule 41    arg_list -> expr
Rule 42    arg_list -> expr , arg_list

